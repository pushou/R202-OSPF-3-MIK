
/system identity set name="Mikrotik2"

/interface bridge add name=loopback protocol-mode=none


/ip address add interface=loopback address=10.0.0.2/32




/interface ethernet set comment="Mikrotik2 -> Mikrotik1" ether2

/ip address add interface=ether2 address=10.1.0.2/30
/ip address set [find where interface=ether2] comment="Mikrotik2 -> Mikrotik1"


/interface ethernet set comment="Mikrotik2 -> Mikrotik3" ether3

/ip address add interface=ether3 address=10.1.0.5/30
/ip address set [find where interface=ether3] comment="Mikrotik2 -> Mikrotik3"


/ip neighbor discovery-settings set discover-interface-list=all